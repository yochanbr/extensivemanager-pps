{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/admin", "destination": "/server.js" },
    { "source": "/employee", "destination": "/server.js" },
    { "source": "/counter_selection", "destination": "/server.js" },
    { "source": "/scan", "destination": "/server.js" },
    { "source": "/login", "destination": "/server.js" },
    { "source": "/", "destination": "/server.js" }
  ]
}
