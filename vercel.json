{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/employee", "destination": "/employee.html" },
    { "source": "/counter_selection", "destination": "/counter_selection.html" },
    { "source": "/scan", "destination": "/scan.html" },
    { "source": "/login", "destination": "/index.html" }
  ]
}
