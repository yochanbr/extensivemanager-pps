{
  "version": 2,
  "functions": {
    "server.js": {
      "includeFiles": "*.{html,css,js,json,db,png,jpg,svg,gif,ico,min.js}"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(admin|employee|counter_selection|scan|login|register)",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
